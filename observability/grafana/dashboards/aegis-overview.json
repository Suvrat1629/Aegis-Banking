{
  "annotations": {"list": []},
  "description": "End-to-end health and performance of the Aegis Banking system — Gateway (SOAP/gRPC), Ledger-Core (Go), and supporting infrastructure.",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["aegis", "banking"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Aegis Banking — Overview",
  "uid": "aegis-banking-overview",
  "version": 2,
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Metrics Source"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "jaeger_datasource",
        "options": [],
        "query": "jaeger",
        "refresh": 1,
        "type": "datasource",
        "label": "Tracing Source"
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Ledger: Total Requests",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "aegis_ledger_transfer_requests_total",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "blue", "mode": "fixed"},
          "unit": "short"
        },
        "overrides": []
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Ledger: Success Rate",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "aegis_ledger_transfer_success_total / aegis_ledger_transfer_requests_total * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 80},
              {"color": "green", "value": 95}
            ]
          },
          "unit": "percent",
          "max": 100,
          "min": 0
        },
        "overrides": []
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Ledger: Total Failures",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
