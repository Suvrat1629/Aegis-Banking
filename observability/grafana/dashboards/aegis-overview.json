        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(aegis_ledger_transfer_failure_total)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
